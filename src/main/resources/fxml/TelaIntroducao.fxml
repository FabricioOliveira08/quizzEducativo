<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox alignment="CENTER" prefHeight="650.0" prefWidth="850.0"
      stylesheets="@../css/style.css" styleClass="root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.quizeducativo.controller.TelaIntroducaoController">

    <VBox alignment="CENTER" maxWidth="750.0" spacing="25.0" styleClass="cartao, cartao-introducao">

        <Label styleClass="titulo" text="O Superpoder da Repetição! ⚡" />
        <Label wrapText="true" textAlignment="CENTER" styleClass="texto-introducao"
               text="Imagine que você está num videogame e precisa pegar 100 moedas. Em vez de apertar o botão 'Pegar' 100 vezes, nós usamos os Loops! Eles mandam o computador repetir a tarefa sozinho." />

        <Region prefHeight="10.0" />

        <HBox alignment="CENTER" spacing="30.0">

            <VBox alignment="TOP_CENTER" prefWidth="420.0" spacing="15.0" styleClass="card-laco">
                <Label text="🎯 O 'FOR' (Para)" styleClass="titulo-laco"/>
                <Label wrapText="true" textAlignment="CENTER" text="Usamos quando sabemos a quantidade exata." styleClass="texto-laco"/>

                <Region prefHeight="5.0" />

                <Label wrapText="true" textAlignment="CENTER" text="Ex.: 'Dê exatamente 5 pulos!'" styleClass="exemplo-laco"/>
                <ImageView fitHeight="80.0" preserveRatio="true">
                    <image>
                        <Image url="@../images/for_pular.png" />
                    </image>
                </ImageView>
            </VBox>

            <VBox alignment="TOP_CENTER" prefWidth="420.0" spacing="15.0" styleClass="card-laco">
                <Label text="🔋 O 'WHILE' (Enquanto)" styleClass="titulo-laco"/>
                <Label wrapText="true" textAlignment="CENTER" text="Usamos quando queremos repetir até algo acontecer." styleClass="texto-laco"/>

                <Region prefHeight="5.0" />

                <Label wrapText="true" textAlignment="CENTER" text="Ex.: 'ande enquanto tiver energia!'" styleClass="exemplo-laco"/>

                <ImageView fitHeight="80.0" preserveRatio="true">
                    <image>
                        <Image url="@../images/while_energia.png" />
                    </image>
                </ImageView>
            </VBox>

        </HBox>

        <Region prefHeight="15.0" />

        <Button fx:id="btnIniciarQuiz" mnemonicParsing="false" onAction="#iniciarQuiz"
                prefHeight="55.0" prefWidth="350.0" styleClass="button, btn-gamificado"
                text="ESTOU PRONTO! 🎮" />
    </VBox>
</VBox>