<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="550.0" prefWidth="700.0"
      stylesheets="@../css/style.css" styleClass="root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.quizeducativo.controller.TelaResultadoController">

    <VBox alignment="CENTER" maxWidth="450.0" spacing="30.0" styleClass="cartao">

        <Label styleClass="titulo" text="Fim de Jogo!" />

        <VBox alignment="CENTER" spacing="10.0" styleClass="caixa-pontuacao">
            <Label styleClass="subtitulo" text="Parabéns," style="-fx-font-size: 18px;" />
            <Label fx:id="labelNome" styleClass="titulo" text="[Nome]" style="-fx-font-size: 24px;" />

            <Region prefHeight="10.0" />

            <Label styleClass="subtitulo" text="Sua Pontuação Final:" />
            <Label fx:id="labelSuaPontuacao" styleClass="pontuacao-gigante" text="X / 10" />
        </VBox>

        <Button fx:id="btnVoltarMenu" mnemonicParsing="false" onAction="#voltarAoMenu" prefHeight="45.0" prefWidth="250.0" styleClass="button" text="JOGAR NOVAMENTE" />

    </VBox>
</VBox>