<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="450.0" prefWidth="600.0" spacing="20.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.quizeducativo.controller.TelaInicialController">

    <Label text="Quiz Educativo: Laços de Repetição" textAlignment="CENTER">
        <font>
            <Font name="System Bold" size="28.0" />
        </font>
        <VBox.margin>
            <Insets bottom="30.0" />
        </VBox.margin>
    </Label>

    <TextField fx:id="campoNome" maxWidth="250.0" promptText="Digite seu nome..." />

    <Button fx:id="btnIniciar" mnemonicParsing="false" onAction="#iniciarQuiz" prefHeight="40.0" prefWidth="250.0" text="[ Novo Jogo ]" />

    <Button mnemonicParsing="false" prefHeight="40.0" prefWidth="250.0" text="[ Ver Resultados ]" />

</VBox>